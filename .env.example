# WaldoSpells environment configuration
# Copy this file to .env and fill in your local paths.
# .env is gitignored — never commit it with real paths.

# Path to the CTranslate2-converted T5 model directory (must contain model.bin)
CT2_MODEL_PATH=/absolute/path/to/WaldoSpells/models/gec-t5_small-ct2

# Path to the Qwen2.5-3B-Instruct GGUF model file
LLAMA_MODEL_PATH=/absolute/path/to/WaldoSpells/models/qwen2.5-3b-instruct-q4_k_m.gguf

# Optional: path to llama-server binary (defaults to PATH lookup)
# LLAMA_SERVER_BIN=/absolute/path/to/llama-server
