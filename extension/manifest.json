{
  "manifest_version": 3,
  "name": "Waldo Spells",
  "version": "0.4.0",
  "description": "Context-aware local spelling and word-choice checker. Runs entirely on your machine.",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "https://huggingface.co/*",
    "https://cdn.jsdelivr.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.svg"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' blob: 'wasm-unsafe-eval'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "waldo-spells@waldo.local",
      "strict_min_version": "112.0"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["vendor/*", "models/**"],
      "matches": ["<all_urls>"]
    }
  ]
}
